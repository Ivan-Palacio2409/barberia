# ── Google Maps Platform ──────────────────────────────────────
# Restringir a dominios específicos en Google Cloud Console
# Ya NO se usa: el mapa ahora usa el embed público de Google Maps
# (sin API key). Se deja comentado por si en el futuro se quiere
# una integración más avanzada (autocompletado de direcciones, etc).
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=


# ── Resend (email) — H5 ─────────────────────────────────────────
# Solo en el entorno servidor (Route Handlers). Sin esta key, el
# EmailProvider loguea una advertencia y no envía nada (no rompe el flujo).
RESEND_API_KEY=
# Remitente verificado en Resend, ej: "FORMA <notificaciones@tudominio.com>"
# Mientras no configures un dominio propio, usa onboarding@resend.dev (modo pruebas).
RESEND_FROM_EMAIL=

# ── WhatsApp Business API (Cloud API) — H5 ─────────────────────
# Sin estas dos, el WhatsAppProvider falla y el dispatcher cae a email automáticamente.
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_ID=

# ── Contacto del ADMIN (para notificaciones al negocio) ─────────
# A dónde llegan: nueva reserva, resumen de mañana, recordatorio
# 1h antes. Si dejas ambos vacíos, esas notificaciones se omiten.
ADMIN_EMAIL=
ADMIN_WHATSAPP_PHONE=

# ── Cron de notificaciones — H5 ─────────────────────────────────
# Secreto compartido para autorizar POST a /api/notificaciones/procesar
# y /api/notificaciones/resumen-diario.
# Generar uno random (ej: `openssl rand -hex 32`) y usarlo también
# en la configuración del cron (Vercel Cron o pg_cron). Sin esto
# configurado, el endpoint responde 503 y no procesa nada.
CRON_SECRET=

# ── Analítica (elegir uno) [C4] ───────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
# O Plausible:
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# O GA4:
NEXT_PUBLIC_GA4_ID=

# ── Web Push (VAPID) — Fase 30 ────────────────────────────────
# Generar con: npx web-push generate-vapid-keys
# La clave publica va en el cliente; la privada SOLO en servidor.
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contacto@forma-peluqueria.com
